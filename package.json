{
  "name": "delicious24",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "db:generate": "npm run db:generate -w @delicious24/db",
    "db:migrate": "npm run db:migrate -w @delicious24/db",
    "db:push": "npm run db:push -w @delicious24/db",
    "db:studio": "npm run db:studio -w @delicious24/db",
    "build:api": "npm run build -w @delicious24/api",
    "dev:api": "npm run start:dev -w @delicious24/api",
    "dev:worker": "npm run start:worker:dev -w @delicious24/api",
    "build:console": "npm run build -w @delicious24/console",
    "dev:console": "npm run dev -w @delicious24/console"
  },
  "overrides": {
    "rxjs": "7.8.1"
  }
}
