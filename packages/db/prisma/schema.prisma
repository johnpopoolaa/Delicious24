// Canonical database schema — see docs/architecture.md

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum RiskSegment {
  VIP
  SAFE
  RISK
  BANNED
}

enum OrderType {
  PAID
  CREDIT
}

enum CreditStatus {
  ACTIVE
  PENDING_VERIFICATION
  SETTLED
  DEFAULTED
}

enum TransactionKind {
  CHARGE
  PAYMENT
  REFUND
}

enum ScheduledJobType {
  COURTESY
  URGENT
  OVERDUE
  MANUAL
  APPRECIATION
}

enum ScheduledJobStatus {
  PENDING
  RUNNING
  CANCELLED
  FAILED
  COMPLETED
}

enum PendingPaymentCandidateStatus {
  NEW
  REVIEWED
  REJECTED
}

enum ReconciliationTaskStatus {
  OPEN
  RESOLVED
  DISMISSED
}

enum NotifChannel {
  WHATSAPP
  SMS
  BOTH
}

model Customer {
  id                 String      @id @default(uuid()) @db.Uuid
  phone              String      @unique
  email              String?
  name               String
  trustScore         Int         @default(50) @map("trust_score")
  riskSegment        RiskSegment @default(SAFE) @map("risk_segment")
  storeCreditBalance Decimal      @default(0) @map("store_credit_balance") @db.Decimal(10, 2)
  notifChannel       NotifChannel @default(WHATSAPP) @map("notif_channel")
  createdAt          DateTime    @default(now()) @map("created_at")
  updatedAt          DateTime    @updatedAt @map("updated_at")

  orders            Order[]
  credits           Credit[]
  trustScoreEvents  TrustScoreEvent[]
  scheduledJobs     ScheduledJob[] @relation("CustomerScheduledJobs")

  @@map("customers")
}

model MenuItem {
  id         Int         @id @default(autoincrement())
  name       String
  price      Decimal     @db.Decimal(10, 2)
  inStock    Boolean     @default(true) @map("in_stock")
  archivedAt DateTime?   @map("archived_at")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")
  orderLines OrderLine[]

  @@map("menu_items")
}

model Order {
  id         String    @id @default(uuid()) @db.Uuid
  customerId String    @map("customer_id") @db.Uuid
  total      Decimal   @db.Decimal(10, 2)
  type       OrderType
  note       String?
  createdAt  DateTime  @default(now()) @map("created_at")

  customer     Customer      @relation(fields: [customerId], references: [id])
  lines        OrderLine[]
  credits      Credit[]
  transactions Transaction[]

  @@index([customerId])
  @@map("orders")
}

model OrderLine {
  id         String   @id @default(uuid()) @db.Uuid
  orderId    String   @map("order_id") @db.Uuid
  menuItemId Int      @map("menu_item_id")
  quantity   Int
  unitPrice  Decimal  @map("unit_price") @db.Decimal(10, 2)

  order    Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  menuItem MenuItem @relation(fields: [menuItemId], references: [id])

  @@index([orderId])
  @@map("order_lines")
}

model Credit {
  id            String       @id @default(uuid()) @db.Uuid
  orderId       String?      @map("order_id") @db.Uuid
  customerId    String       @map("customer_id") @db.Uuid
  principal     Decimal      @db.Decimal(10, 2)
  balance       Decimal      @db.Decimal(10, 2)
  dueDate       DateTime     @map("due_date")
  status        CreditStatus
  remindersSent Int          @default(0) @map("reminders_sent")
  createdAt     DateTime     @default(now()) @map("created_at")
  updatedAt     DateTime     @updatedAt @map("updated_at")

  order                      Order?                    @relation(fields: [orderId], references: [id])
  customer                   Customer                  @relation(fields: [customerId], references: [id])
  transactions               Transaction[]
  scheduledJobs              ScheduledJob[]
  pendingPaymentCandidates   PendingPaymentCandidate[]

  @@index([customerId])
  @@index([orderId])
  @@index([status])
  @@map("credits")
}

model Transaction {
  id        String          @id @default(uuid()) @db.Uuid
  creditId  String?         @map("credit_id") @db.Uuid
  orderId   String?         @map("order_id") @db.Uuid
  amount    Decimal         @db.Decimal(10, 2)
  kind      TransactionKind
  note      String?
  createdAt DateTime        @default(now()) @map("created_at")

  credit Credit? @relation(fields: [creditId], references: [id])
  order  Order?  @relation(fields: [orderId], references: [id])

  @@index([creditId])
  @@index([orderId])
  @@map("transactions")
}

model ScheduledJob {
  id         String               @id @default(uuid()) @db.Uuid
  jobKey     String               @unique @map("job_key")
  creditId   String?              @map("credit_id") @db.Uuid
  customerId String?              @map("customer_id") @db.Uuid
  type       ScheduledJobType
  runAt      DateTime             @map("run_at")
  status     ScheduledJobStatus   @default(PENDING)
  attempts   Int                  @default(0)
  lastError  String?              @map("last_error")
  createdAt  DateTime             @default(now()) @map("created_at")
  updatedAt  DateTime             @updatedAt @map("updated_at")

  credit   Credit?   @relation(fields: [creditId], references: [id])
  customer Customer? @relation("CustomerScheduledJobs", fields: [customerId], references: [id])
  notificationLogs NotificationLog[]

  @@index([creditId])
  @@index([customerId])
  @@index([status, runAt])
  @@map("scheduled_jobs")
}

model TrustScoreEvent {
  id         String   @id @default(uuid()) @db.Uuid
  customerId String   @map("customer_id") @db.Uuid
  delta      Int
  reason     String
  sourceId   String?  @map("source_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  customer Customer @relation(fields: [customerId], references: [id])

  @@index([customerId])
  @@map("trust_score_events")
}

model AuditLog {
  id          String   @id @default(uuid()) @db.Uuid
  actor       String
  action      String
  targetTable String   @map("target_table")
  targetId    String?  @map("target_id") @db.Uuid
  payload     Json
  createdAt   DateTime @default(now()) @map("created_at")

  @@index([targetTable, targetId])
  @@index([createdAt])
  @@map("audit_log")
}

model PendingPaymentCandidate {
  id              String                        @id @default(uuid()) @db.Uuid
  fromPhone       String                        @map("from_phone")
  parsedAmount    Decimal?                      @map("parsed_amount") @db.Decimal(10, 2)
  rawText         String                        @map("raw_text")
  matchedCreditId String?                       @map("matched_credit_id") @db.Uuid
  status          PendingPaymentCandidateStatus @default(NEW)
  createdAt       DateTime                      @default(now()) @map("created_at")

  matchedCredit Credit? @relation(fields: [matchedCreditId], references: [id])

  @@index([fromPhone])
  @@index([status])
  @@map("pending_payment_candidates")
}

model IdempotencyRequest {
  id           String   @id @default(uuid()) @db.Uuid
  key          String   @map("idempotency_key")
  route        String
  responseBody Json     @map("response_body")
  statusCode   Int      @map("status_code")
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([key, route])
  @@index([createdAt])
  @@map("idempotency_requests")
}

model ReconciliationTask {
  id         String                     @id @default(uuid()) @db.Uuid
  clientId   String?                    @map("client_id")
  entityType String                     @map("entity_type")
  payload    Json
  status     ReconciliationTaskStatus   @default(OPEN)
  createdAt  DateTime                   @default(now()) @map("created_at")
  resolvedAt DateTime?                  @map("resolved_at")

  @@index([status])
  @@map("reconciliation_tasks")
}

model NotificationLog {
  id             String       @id @default(uuid()) @db.Uuid
  scheduledJobId String       @map("scheduled_job_id") @db.Uuid
  channel        NotifChannel
  toPhone        String       @map("to_phone")
  messageSid     String?      @map("message_sid")
  status         String
  error          String?
  createdAt      DateTime     @default(now()) @map("created_at")

  scheduledJob ScheduledJob @relation(fields: [scheduledJobId], references: [id])

  @@index([scheduledJobId])
  @@map("notification_logs")
}
